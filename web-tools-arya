



<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Aryakk Premium Tools Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
:root {
  --bg-dark: #090a0f;
  --panel-dark: rgba(18, 20, 28, 0.65); /* Dibuat sedikit transparan agar video samar terlihat */
  --panel-light: rgba(26, 29, 41, 0.75);
  --border-color: rgba(255, 255, 255, 0.08);
  --text-main: #f3f4f6;
  --text-muted: #878c9e;
  --accent-cyan: #00f2fe;
  --accent-blue: #4facfe;
  --accent-green: #1db954;
  --accent-indigo: #6366f1;
  --gradient-primary: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
  --gradient-brat: linear-gradient(135deg, #bfff00 0%, #80cc00 100%);
  --gradient-music: linear-gradient(135deg, #1db954 0%, #191414 100%);
  --gradient-ai: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Plus Jakarta Sans', -apple-system, sans-serif;
  background-color: var(--bg-dark);
  color: var(--text-main);
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 24px 16px 80px;
  overflow-x: hidden;
}

/* ==========================================================================
   VIDEO BACKGROUND CORE COMPONENT
   ========================================================================= */
.video-background {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  overflow: hidden;
  display: none; /* Disembunyikan saat login, tampil via JS saat masuk dashboard */
}
.video-background video {
  min-width: 100%;
  min-height: 100%;
  width: auto;
  height: auto;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  object-fit: cover;
}
.video-background::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(9, 10, 15, 0.55); /* Tint warna gelap 55% agar teks kontras */
}

.animate-btn {
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.2s ease, background-color 0.2s ease !important;
}
.btn-clicked {
  transform: scale(0.92) !important;
  opacity: 0.85 !important;
}

.app-container { width: 100%; max-width: 440px; display: flex; flex-direction: column; gap: 20px; }

.login-screen {
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 400px;
  margin-top: 40px;
}
.login-card {
  background: #12141c;
  border: 1px solid var(--border-color);
  border-radius: 24px;
  padding: 28px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.5);
}

.main-dashboard-wrapper {
  display: none;
  width: 100%;
  flex-direction: column;
  gap: 20px;
}

.app-header {
  background: rgba(18, 20, 28, 0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--border-color);
  border-radius: 20px;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 10px;
  z-index: 900;
}
.header-brand { display: flex; align-items: center; gap: 10px; cursor: pointer; }
.brand-icon { width: 36px; height: 36px; background: var(--gradient-primary); border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #000; font-weight: 700; }
.brand-name { font-size: 16px; font-weight: 700; }

.nav-trigger { 
  width: 40px; height: 40px; background: var(--panel-light); border: 1px solid var(--border-color); border-radius: 10px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--text-main);
}

.nav-dropdown {
  position: absolute; top: 70px; right: 16px; background: #12141c; border: 1px solid var(--border-color); border-radius: 16px; width: 200px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); display: none; flex-direction: column; overflow: hidden; z-index: 999;
}
.nav-dropdown.show { display: flex; }
.dropdown-item { padding: 14px 16px; font-size: 14px; font-weight: 600; color: var(--text-main); display: flex; align-items: center; gap: 12px; cursor: pointer; border-bottom: 1px solid rgba(255,255,255,0.03); }
.dropdown-item:hover { background: var(--panel-light); color: var(--accent-cyan); }
.menu-backdrop { position: fixed; inset: 0; z-index: 850; display: none; }
.menu-backdrop.show { display: block; }

.quick-tabs { display: flex; background: rgba(18, 20, 28, 0.5); padding: 4px; border-radius: 14px; border: 1px solid var(--border-color); gap: 4px; overflow-x: auto; }
.quick-tabs::-webkit-scrollbar { display: none; }
.q-tab { flex: 1; min-width: 75px; padding: 10px 4px; text-align: center; font-size: 11px; font-weight: 700; color: var(--text-muted); border-radius: 10px; cursor: pointer; text-transform: uppercase; white-space: nowrap; }
.q-tab.active { background: var(--panel-light); color: var(--accent-cyan); }

.page-view { display: none; flex-direction: column; gap: 20px; }
.page-view.active { display: flex; }

.premium-card { 
  background: var(--panel-dark); 
  border: 1px solid var(--border-color); 
  border-radius: 24px; 
  padding: 24px; 
  position: relative; 
  overflow: hidden;
  backdrop-filter: blur(10px); /* Efek Glassmorphism di atas video background */
  -webkit-backdrop-filter: blur(10px);
}
.premium-card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px; background: var(--gradient-primary); opacity: 0.7; }

.profile-section { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 10px 0; }
.avatar-wrapper { position: relative; width: 100px; height: 100px; margin-bottom: 14px; }
.avatar-glow { position: absolute; inset: -4px; background: linear-gradient(135deg, var(--accent-cyan), #7f00ff); border-radius: 50%; z-index: 1; animation: spin 4s linear infinite; }
@keyframes spin { 100% { transform: rotate(360deg); } }
.avatar-image { position: absolute; inset: 2px; background: #000; border-radius: 50%; z-index: 2; overflow: hidden; }
.avatar-image img { width: 100%; height: 100%; object-fit: cover; }

.action-grid { display: flex; flex-direction: column; gap: 12px; width: 100%; margin-top: 20px; }
.action-row-btn { background: var(--panel-light); border: 1px solid var(--border-color); border-radius: 16px; padding: 16px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; }
.action-row-btn:hover { border-color: var(--accent-cyan); }
.btn-meta-left { display: flex; align-items: center; gap: 14px; }
.btn-meta-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; }
.btn-meta-text { display: flex; flex-direction: column; text-align: left; }
.btn-main-title { font-size: 14px; font-weight: 700; color: var(--text-main); }
.btn-sub-title { font-size: 11px; color: var(--text-muted); }

.form-group { margin-bottom: 14px; display: flex; flex-direction: column; gap: 6px; width: 100%; }
.field-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-muted); }
input[type="text"], input[type="password"], input[type="number"], textarea, select { width: 100%; background: rgba(255,255,255,0.03); border: 1px solid var(--border-color); border-radius: 12px; padding: 12px 14px; color: var(--text-main); font-size: 14px; outline: none; transition: border-color 0.2s ease; }
input:focus, textarea:focus, select:focus { border-color: var(--accent-cyan); }
.row-split { display: flex; gap: 10px; }
.row-split > * { flex: 1; }

.chip-group { display: flex; gap: 8px; background: rgba(0,0,0,0.2); padding: 4px; border-radius: 12px; border: 1px solid var(--border-color); }
.selector-chip { flex: 1; padding: 8px 12px; font-size: 13px; font-weight: 600; text-align: center; color: var(--text-muted); cursor: pointer; border-radius: 8px; }
.selector-chip.active { background: var(--gradient-primary); color: #000; font-weight: 700; }

.btn-block-primary { 
  width: 100%; background: var(--gradient-primary); border: none; padding: 14px; border-radius: 14px; color: #000; font-size: 15px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; outline: none; 
}
.btn-block-secondary { 
  width: 100%; background: transparent; border: 1px solid var(--border-color); padding: 12px; border-radius: 14px; color: var(--text-main); font-size: 14px; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; 
}

/* Phone Mockup Layout */
.phone-shell { width: 100%; background: #000000; border-radius: 0px; border: 6px solid #222530; position: relative; display: flex; flex-direction: column; overflow: visible; }
.phone-inner-container { width: 100%; border-radius: 0px; overflow: hidden; position: relative; display: flex; flex-direction: column; background: #000000; }

.ios-status-bar { background: #000000; height: 44px; display: flex; align-items: flex-end; justify-content: space-between; padding: 0 20px 8px; color: #ffffff; }
.ios-time { font-size: 14px; font-weight: 600; }
.ios-hardware-status { display: flex; align-items: center; gap: 6px; }
.signal-bars { display: flex; gap: 2px; align-items: flex-end; }
.signal-bars span { background: #ffffff; width: 3px; border-radius: 0.5px; }
.battery-ios-ui { display: flex; align-items: center; gap: 4px; }
.bat-body-shell { width: 22px; height: 11px; border: 1px solid rgba(255,255,255,0.5); border-radius: 3px; padding: 1px; display: flex; position: relative; }
.bat-body-shell::after { content: ''; position: absolute; right: -3px; top: 3px; width: 2px; height: 3px; background: rgba(255,255,255,0.5); border-radius: 0 1px 1px 0; }
.bat-core-fill { height: 100%; border-radius: 1.5px; }

.ios-navigation-header { background: #16161a; border-bottom: 0.5px solid rgba(255, 255, 255, 0.12); padding: 10px 14px; display: flex; align-items: center; justify-content: space-between; }
.ios-back-action { color: #0a84ff; font-size: 15px; display: flex; align-items: center; gap: 4px; cursor: pointer; }
.ios-avatar-center { display: flex; flex-direction: column; align-items: center; }
.ios-contact-initial { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #8e8e93 0%, #636366 100%); color: #ffffff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; margin-bottom: 2px; }
.ios-contact-title { font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.6); }
.ios-actions-right { display: flex; gap: 16px; color: #0a84ff; font-size: 16px; align-items: center; }

.ios-chat-viewport { background: #000000; padding: 16px 12px; display: flex; flex-direction: column; gap: 8px; position: relative; min-height: 520px; }
.timeline-stamp { text-align: center; font-size: 11px; font-weight: 600; color: #8e8e93; margin-bottom: 6px; }
.msg-stream-row { display: flex; align-items: flex-end; gap: 8px; width: 100%; }
.avatar-attachment-ui { width: 28px; height: 28px; border-radius: 50%; background: #3a3a3c; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; color: #ffffff; }
.bubble-bundle { display: flex; flex-direction: column; max-width: 75%; position: relative; }
.bubble-msg-node { padding: 10px 14px; border-radius: 18px; font-size: 16px; line-height: 1.4; word-break: break-word; background: #262629; color: #ffffff; border-bottom-left-radius: 18px; position: relative; }
.bubble-meta-timestamp { font-size: 10px; color: #8e8e93; margin-top: 3px; padding: 0 4px; }

/* Context Menu UI - MATCHED TO THE REACTION PRESET IMAGE */
.ios-blur-context-overlay { 
  position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 999; background: rgba(0, 0, 0, 0.2); backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px); padding: 60px 16px 16px; display: none; flex-direction: column; align-items: flex-start; gap: 12px; 
}
.ios-blur-context-overlay.active { display: flex; }

.reaction-pill-bar { 
  background: #1c1c1e; border-radius: 30px; padding: 8px 18px; display: flex; width: auto; max-width: 100%; justify-content: space-between; font-size: 24px; box-shadow: 0 8px 24px rgba(0,0,0,0.4); gap: 14px; position: relative; margin-bottom: 5px;
}
/* Ekor kecil gelembung menu reaksi bulat iOS */
.reaction-pill-bar::after {
  content: ''; position: absolute; bottom: -6px; left: 24px; width: 12px; height: 12px; background: #1c1c1e; border-radius: 50%; box-shadow: -4px 5px 0 -1px #1c1c1e;
}

.context-focused-bubble-group { display: flex; flex-direction: column; align-items: flex-start; width: 100%; margin-bottom: 8px; }
.context-isolated-bubble { 
  background: #262629; color: #ffffff; padding: 10px 16px; border-radius: 18px; font-size: 16px; max-width: 75%; position: relative; line-height: 1.4;
}
/* Pembuatan ekor gelembung chat iMessage sisi kiri bawah */
.context-isolated-bubble::before, .bubble-msg-node::before {
  content: ""; position: absolute; bottom: 0; left: -5px; height: 20px; width: 10px; background: #262629; border-bottom-right-radius: 15px 12px;
}
.context-isolated-bubble::after, .bubble-msg-node::after {
  content: ""; position: absolute; bottom: 0; left: -10px; height: 20px; width: 10px; background: #000000; border-bottom-right-radius: 10px;
}

.context-action-vertical-menu { background: #1c1c1e; border-radius: 14px; width: 100%; max-width: 230px; overflow: hidden; box-shadow: 0 15px 30px rgba(0,0,0,0.5); display: flex; flex-direction: column; }
.context-menu-node { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; font-size: 15px; font-weight: 400; color: #ffffff; border-bottom: 0.5px solid rgba(255,255,255,0.08); cursor: pointer; }
.context-menu-node i { color: #ffffff; font-size: 15px; opacity: 0.8; }
.context-menu-node.destructive { color: #ff453a; }
.context-menu-node.destructive i { color: #ff453a; }

.ios-system-input-bar { background: #16161a; border-top: 0.5px solid rgba(255, 255, 255, 0.12); padding: 8px 12px; display: flex; align-items: center; gap: 10px; }
.ios-input-icon-add { width: 28px; height: 28px; background: #2c2c2e; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #ffffff; }
.ios-input-placeholder-field { flex: 1; background: #000000; border: 1px solid #2c2c2e; border-radius: 15px; padding: 6px 14px; color: #8e8e93; font-size: 14px; }
.ios-input-icon-send { width: 28px; height: 28px; background: #0a84ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #ffffff; font-size: 12px; }
.ios-home-indicator-bar { background: #16161a; height: 20px; display: flex; align-items: center; justify-content: center; }
.ios-home-pill { width: 110px; height: 5px; background: rgba(255,255,255,0.3); border-radius: 3px; }

/* Brat Canvas Core */
.brat-render-canvas { width: 100%; aspect-ratio: 1/1; background: #ffffff; border-radius: 20px; padding: 24px; display: flex; align-items: flex-start; justify-content: flex-start; overflow: hidden; }
.brat-core-text { font-family: -apple-system, BlinkMacSystemFont, Arial, sans-serif; font-weight: 500; color: #000000; text-align: left; line-height: 1.25; white-space: pre-wrap; word-break: break-word; width: 100%; letter-spacing: -1.5px; font-size: 34px; }

.app-toast-notif { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(100px); background: rgba(26, 29, 41, 0.95); border: 1px solid var(--border-color); color: #ffffff; font-size: 13px; font-weight: 600; padding: 10px 20px; border-radius: 30px; box-shadow: 0 10px 25px rgba(0,0,0,0.4); transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); z-index: 10000; display: flex; align-items: center; gap: 8px; }
.app-toast-notif.active { transform: translateX(-50%) translateY(0); }

/* Music Engine UI */
.music-track-card { display: flex; flex-direction: column; gap: 14px; background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); padding: 20px; border-radius: 20px; }
.audio-native-element { width: 100%; margin-top: 6px; height: 40px; outline: none; }
.available-songs-container { margin-top: 14px; padding: 12px 16px; background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border-color); border-radius: 14px; }
.available-songs-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--accent-cyan); margin-bottom: 8px; }
.song-list-item { font-size: 13px; color: var(--text-main); padding: 4px 0; display: flex; align-items: center; gap: 8px; }
.song-list-item i { font-size: 10px; color: var(--text-muted); }

/* ==========================================================================
   ARIYA AI ENGINE WINDOW STYLE
   ========================================================================== */
.ai-chat-container { display: flex; flex-direction: column; background: rgba(0,0,0,0.3); border: 1px solid var(--border-color); border-radius: 20px; height: 460px; overflow: hidden; }
.ai-messages-window { flex: 1; overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 12px; }
.ai-messages-window::-webkit-scrollbar { display: none; }
.ai-msg-row { display: flex; align-items: flex-start; gap: 10px; max-width: 85%; }
.ai-msg-row.user { margin-left: auto; flex-direction: row-reverse; }
.ai-msg-avatar { width: 32px; height: 32px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0; border: 1px solid rgba(255,255,255,0.08); }
.ai-msg-avatar.user { background: #2a2d3d; color: #a1a1aa; }
.ai-msg-avatar.bot { background: rgba(99,102,241,0.15); color: var(--accent-blue); }
.ai-msg-bubble { padding: 10px 14px; border-radius: 16px; font-size: 13.5px; line-height: 1.5; color: #e4e4e7; border: 1px solid rgba(255,255,255,0.05); }
.ai-msg-row.user .ai-msg-bubble { background: #12141c; border-top-right-radius: 0px; }
.ai-msg-row.bot .ai-msg-bubble { background: rgba(26,29,41,0.6); border-top-left-radius: 0px; }
.ai-input-bar-form { display: flex; gap: 8px; padding: 12px; background: #12141c; border-top: 1px solid var(--border-color); align-items: center; }
.ai-input-field { flex: 1; background: #090a0f; border: 1px solid var(--border-color); border-radius: 12px; padding: 10px 14px; color: #fff; font-size: 13.5px; outline: none; }
.ai-input-field:focus { border-color: var(--accent-indigo); }
.ai-send-btn { width: 40px; height: 40px; background: var(--accent-indigo); border: none; border-radius: 12px; color: #fff; display: flex; align-items: center; justify-content: center; cursor: pointer; }
.ai-send-btn:disabled { background: #1c1e2a; color: #4b4e69; cursor: not-allowed; }
@keyframes blink { 50% { opacity: 0; } }
.ai-cursor-blink { display: inline-block; width: 2px; height: 13px; background: var(--accent-blue); margin-left: 2px; animation: blink 1s infinite; }
</style>
</head>
<body>

<div class="video-background" id="bgVideoComponent">
    <video loop playsinline id="nativeBgVideo">
        <source src="https://files.catbox.moe/xc737p.mp4" type="video/mp4">
    </video>
</div>

<div class="menu-backdrop" id="menuBackdrop" onclick="toggleDropdown()"></div>

<div class="login-screen" id="screenLogin">
  <div class="login-card">
    <div style="text-align: center; margin-bottom: 24px;">
      <div class="brand-icon" style="margin: 0 auto 12px; width: 48px; height: 48px; font-size: 20px;"><i class="fa-solid fa-lock"></i></div>
      <h2 style="font-size: 20px; font-weight: 800;">Aryakk Suite Portal</h2>
      <p style="font-size: 12px; color: var(--text-muted); margin-top: 4px;">Masukkan kredensial User</p>
    </div>

    <div class="form-group">
      <label class="field-label">Username</label>
      <input type="text" id="loginUsername" placeholder="Username Anda...">
    </div>
    <div class="form-group" style="margin-bottom: 20px;">
      <label class="field-label">Password</label>
      <input type="password" id="loginPassword" placeholder="••••••••">
    </div>

    <button class="btn-block-primary animate-btn" onclick="handleSystemAuth()"><i class="fa-solid fa-right-to-bracket"></i> Masuk Sekarang</button>
  </div>
</div>


<div class="main-dashboard-wrapper" id="screenDashboard">
  <div class="app-container">
    
    <header class="app-header">
      <div class="header-brand animate-btn" onclick="navigateToPage('home')">
        <div class="brand-icon"><i class="fa-solid fa-bolt"></i></div>
        <div class="brand-name">aryakk.club</div>
      </div>
      <div class="nav-trigger animate-btn" onclick="toggleDropdown()">
        <i class="fa-solid fa-bars-staggered"></i>
      </div>
      <div class="nav-dropdown" id="navDropdown">
        <div class="dropdown-item animate-btn" onclick="navigateToPage('home')"><i class="fa-solid fa-house"></i> Dashboard</div>
        <div class="dropdown-item animate-btn" onclick="navigateToPage('download-hub')"><i class="fa-solid fa-cloud-arrow-down"></i> Downloader</div>
        <div class="dropdown-item animate-btn" onclick="navigateToPage('imessage-engine')"><i class="fa-solid fa-comment-nodes"></i> iMessage Gen</div>
        <div class="dropdown-item animate-btn" onclick="navigateToPage('brat-engine')"><i class="fa-solid fa-font"></i> Brat Generator</div>
        <div class="dropdown-item animate-btn" onclick="navigateToPage('music-engine')"><i class="fa-solid fa-music"></i> Music Finder</div>
        <div class="dropdown-item animate-btn" onclick="navigateToPage('arya-ai-view')" style="color:var(--accent-indigo);"><i class="fa-solid fa-robot"></i> Ariya AI</div>
        <div class="dropdown-item animate-btn" onclick="navigateToPage('fake-tweet-view')" style="color:#1d9bf0;"><i class="fa-brands fa-twitter"></i> Fake Tweet</div>
        <div class="dropdown-item animate-btn destructive" onclick="handleSystemLogout()" style="border-top: 1px solid rgba(255,255,255,0.05); color: #ff453a;"><i class="fa-solid fa-power-off"></i> Logout</div>
      </div>
    </header>

    <div class="quick-tabs" id="quickTabsPanel" style="display:none;">
