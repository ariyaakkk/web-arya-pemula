// Brat Functionality
function changeBratLayoutMode(mode) {
  globalBratLayoutMode = mode;
  document.getElementById('brat-mode-acak').className = 'selector-chip animate-btn' + (mode === 'acak' ? ' active' : '');
  document.getElementById('brat-mode-samping').className = 'selector-chip animate-btn' + (mode === 'samping' ? ' active' : '');
  document.getElementById('brat-mode-bawah').className = 'selector-chip animate-btn' + (mode === 'bawah' ? ' active' : '');
  document.getElementById('brat-mode-kunci').className = 'selector-chip animate-btn' + (mode === 'kunci' ? ' active' : '');
  processBratRenderingEngine();
}

function processBratRenderingEngine() {
  const rawInputTextString = document.getElementById('inputBratString').value;
  const displayElement = document.getElementById('lblBratTextNode');
  
  if (!rawInputTextString.trim()) {
    displayElement.textContent = rawInputTextString;
    return;
  }
  
  const length = rawInputTextString.length;
  if (length > 60) displayElement.style.fontSize = '22px';
  else if (length > 40) displayElement.style.fontSize = '26px';
  else if (length > 20) displayElement.style.fontSize = '30px';
  else displayElement.style.fontSize = '36px';

  const words = rawInputTextString.trim().split(/\s+/);
  let formattedText = words[0];

  for (let i = 1; i < words.length; i++) {
    if (globalBratLayoutMode === 'bawah') {
      formattedText += "\n" + words[i];
    } else if (globalBratLayoutMode === 'samping' || globalBratLayoutMode === 'kunci') {
      formattedText += " " + words[i];
    } else {
      let seedValue = 0;
      for (let j = 0; j < words[i].length; j++) {
        seedValue += words[i].charCodeAt(j) * (j + 1);
      }
      seedValue += i * 7; 
      const moduloFactor = seedValue % 12;
      if (moduloFactor < 3) {
        formattedText += "\n" + words[i];
      } else if (moduloFactor < 8) {
        const spaceCount = (seedValue % 6) + 3; 
        formattedText += "\n" + " ".repeat(spaceCount) + words[i];
      } else {
        const wideSpaceCount = (seedValue % 5) + 4;
        formattedText += " ".repeat(wideSpaceCount) + words[i];
      }
    }
  }
  displayElement.textContent = formattedText;
}

