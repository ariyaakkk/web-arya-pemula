function initClickAnimationEngine() {
  const targetButtons = document.querySelectorAll('.animate-btn');
  targetButtons.forEach(btn => {
    const pressAction = () => { btn.classList.add('btn-clicked'); };
    const releaseAction = () => { setTimeout(() => { btn.classList.remove('btn-clicked'); }, 80); };

    btn.removeEventListener('touchstart', pressAction);
    btn.removeEventListener('touchend', releaseAction);
    btn.removeEventListener('mousedown', pressAction);
    btn.removeEventListener('mouseup', releaseAction);

    btn.addEventListener('touchstart', pressAction, { passive: true });
    btn.addEventListener('touchend', releaseAction, { passive: true });
    btn.addEventListener('touchcancel', releaseAction, { passive: true });
    btn.addEventListener('mousedown', pressAction);
    btn.addEventListener('mouseup', releaseAction);
    btn.addEventListener('mouseleave', releaseAction);
  });
}

