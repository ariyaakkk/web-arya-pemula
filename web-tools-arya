// Action Kirim Prompt AriyaAI
async function submitAiPromptRequest() {
  const promptInput = document.getElementById('fieldAiPromptInput');
  const sendBtn = document.getElementById('btnAiSendAction');
  const msgWindow = document.getElementById('aiMessagesWindow');
  const text = promptInput.value.trim();

  if(!text) return;

  if(!savedGeminiApiKey) {
    displayGlobalToastNotification('Isi dan simpan Gemini API Key terlebih dahulu!');
    return;
  }

  // Tampilkan pesan user ke UI box
  appendAiMessageBubble('user', text);
  promptInput.value = "";
  sendBtn.disabled = true;

  // Tampilkan bubble loading untuk AI
  const loadingBubble = appendAiMessageBubble('bot', 'AriyaAI sedang berpikir...');
  msgWindow.scrollTop = msgWindow.scrollHeight;

  // Push riwayat chat
  aiChatHistorySession.push({ role: "user", parts: [{ text: text }] });

  const payload = {
    contents: aiChatHistorySession,
    systemInstruction: { parts: [{ text: systemPromptRule }] }
  };

  try {
    const modelName = "gemini-2.5-flash";
    const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/${modelName}:generateContent?key=${savedGeminiApiKey}`;

    const response = await fetch(apiUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });

    if (!response.ok) {
      const errText = await response.text();
      let msg = errText;
      try { const json = JSON.parse(errText); msg = json.error?.message || errText; } catch(e) {}
      throw new Error(msg);
    }

    const data = await response.json();
    const replyText = data.candidates?.[0]?.content?.parts?.[0]?.text || "Gagal mendapatkan balasan.";

    // Hapus teks loading, ganti dengan jawaban asli dari AI
    loadingBubble.querySelector('.ai-msg-bubble').textContent = replyText;
    aiChatHistorySession.push({ role: "model", parts: [{ text: replyText }] });

  } catch (error) {
    aiChatHistorySession.pop(); // batalkan history terakhir jika gagal
    loadingBubble.querySelector('.ai-msg-bubble').innerHTML = `<span style="color:#ff453a; font-weight:700;">Error:</span> ${error.message}`;
  } finally {
    sendBtn.disabled = false;
    msgWindow.scrollTop = msgWindow.scrollHeight;
  }
}

function appendAiMessageBubble(sender, text) {
  const windowContainer = document.getElementById('aiMessagesWindow');
  const row = document.createElement('div');
  row.className = `ai-msg-row ${sender}`;

  const icon = sender === 'user' ? 'fa-user' : 'fa-robot';
  row.innerHTML = `
    <div class="ai-msg-avatar ${sender}"><i class="fa-solid ${icon}"></i></div>
    <div class="ai-msg-bubble">${text}</div>
  `;
  windowContainer.appendChild(row);
  return row;
}

